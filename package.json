{
  "name": "neurodivergent-memory",
  "version": "0.3.0",
  "mcpName": "io.github.jmeyer1980/neurodivergent-memory",
  "description": "A Model Context Protocol server for knowledge graphs designed around neurodivergent thinking patterns",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmeyer1980/neurodivergent-memory.git"
  },
  "bugs": {
    "url": "https://github.com/jmeyer1980/neurodivergent-memory/issues"
  },
  "homepage": "https://github.com/jmeyer1980",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "knowledge-graph",
    "memory",
    "neurodivergent"
  ],
  "author": "jmeyer1980",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "neurodivergent-memory": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "bench": "npm run benchmark",
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "sync-memories": "npm run build && node build/scripts/sync-memories.js",
    "lint": "npm run lint:code && npm run lint:md",
    "lint:code": "tsc --noEmit",
    "lint:md": "npx --yes markdownlint-cli --config .markdownlint.json README.md CHANGELOG.md CONTRIBUTING.md CODE_OF_CONDUCT.md SECURITY.md SUPPORT.md TEST_SUMMARY.md SMOKE_TEST_REPORT.md",
    "test": "npm run build && node --test",
    "smoke:project-id": "npm run build && node test/live-project-id-smoke.mjs",
    "smoke:project-id:target": "node test/live-project-id-smoke.mjs",
    "benchmark": "npm run build && node benchmarks/memory-benchmark.mjs",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.28.0",
    "neurodivergent-memory": "^0.2.0-rc.42.1",
    "pino": "^9.12.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  }
}
